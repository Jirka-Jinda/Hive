# Copy this file to .env and fill in values before starting the app.

# TCP port the backend listens on
PORT=3000

# Directory for SQLite DB and encrypted credentials
DATA_DIR=./packages/backend/data

# Root folder where all repositories live. Clones go here; the local-path picker reads from here.
REPOS_DIR=./repos

# Master password used to encrypt/decrypt stored credential profiles.
# Required in production. In development a warning is shown if empty.
MASTER_PASSWORD=change-me-before-use

# Set to "production" when running via Docker / behind a reverse proxy
NODE_ENV=development
